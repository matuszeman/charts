should match snapshot:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME-api
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: my-app
        app.kubernetes.io/version: 1.0.0
      name: RELEASE-NAME-api
    spec:
      replicas: 1
      revisionHistoryLimit: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME-api
          app.kubernetes.io/name: my-app
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: RELEASE-NAME-api
            app.kubernetes.io/name: my-app
        spec:
          containers:
            - env:
                - name: APP_ENV
                  value: production
              image: 123456.dkr.ecr.eu-central-1.amazonaws.com/my-app:1.0.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                httpGet:
                  path: /healthz
                  port: app
              name: app
              ports:
                - containerPort: 8080
                  name: app
                  protocol: TCP
              resources:
                limits:
                  cpu: 500m
                  memory: 512Mi
                requests:
                  cpu: 100m
                  memory: 128Mi
          enableServiceLinks: false
          nodeSelector: null
          serviceAccountName: RELEASE-NAME
          tolerations: null
          topologySpreadConstraints:
            - labelSelector:
                matchLabels:
                  app.kubernetes.io/instance: RELEASE-NAME-api
                  app.kubernetes.io/name: my-app
              maxSkew: 1
              topologyKey: topology.kubernetes.io/zone
              whenUnsatisfiable: ScheduleAnyway
            - labelSelector:
                matchLabels:
                  app.kubernetes.io/instance: RELEASE-NAME-api
                  app.kubernetes.io/name: my-app
              maxSkew: 1
              topologyKey: kubernetes.io/hostname
              whenUnsatisfiable: ScheduleAnyway
          volumes: null
  2: |
    apiVersion: apps/v1
