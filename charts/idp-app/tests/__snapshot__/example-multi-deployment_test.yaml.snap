            app.kubernetes.io/name: my-app
        spec:
          containers:
            - command:
                - scheduler
              env:
                - name: APP_ENV
                  value: production
              image: 123456.dkr.ecr.eu-central-1.amazonaws.com/my-app:1.0.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                httpGet:
                  path: /healthz
                  port: app
              name: app
              ports:
                - containerPort: 8080
                  name: app
                  protocol: TCP
              resources:
                limits:
                  cpu: 500m
                  memory: 512Mi
                requests:
                  cpu: 50m
                  memory: 64Mi
          enableServiceLinks: false
          nodeSelector: null
          serviceAccountName: RELEASE-NAME
          tolerations: null
          topologySpreadConstraints:
            - labelSelector:
                matchLabels:
                  app.kubernetes.io/instance: RELEASE-NAME-scheduler
                  app.kubernetes.io/name: my-app
              maxSkew: 1
              topologyKey: topology.kubernetes.io/zone
              whenUnsatisfiable: ScheduleAnyway
            - labelSelector:
                matchLabels:
