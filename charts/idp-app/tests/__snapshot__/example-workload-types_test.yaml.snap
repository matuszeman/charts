cronjob:
  1: |
    apiVersion: batch/v1
    kind: CronJob
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: my-app
        app.kubernetes.io/version: 1.0.0
      name: RELEASE-NAME
    spec:
      concurrencyPolicy: Forbid
      failedJobsHistoryLimit: 3
      jobTemplate:
        metadata:
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: my-app
            app.kubernetes.io/version: 1.0.0
        spec:
          template:
            metadata:
              labels:
                app.kubernetes.io/instance: RELEASE-NAME
                app.kubernetes.io/name: my-app
            spec:
              containers:
                - image: 123456.dkr.ecr.eu-central-1.amazonaws.com/my-app:1.0.0
                  imagePullPolicy: IfNotPresent
                  name: app
                  ports:
                    - containerPort: 8080
                      name: app
                      protocol: TCP
                  resources:
                    requests:
                      cpu: 100m
                      memory: 128Mi
              enableServiceLinks: false
              nodeSelector: null
              restartPolicy: OnFailure
              serviceAccountName: RELEASE-NAME
              tolerations: null
              topologySpreadConstraints:
                - labelSelector:
                    matchLabels:
                      app.kubernetes.io/instance: RELEASE-NAME
                      app.kubernetes.io/name: my-app
                  maxSkew: 1
                  topologyKey: topology.kubernetes.io/zone
                  whenUnsatisfiable: ScheduleAnyway
                - labelSelector:
                    matchLabels:
                      app.kubernetes.io/instance: RELEASE-NAME
                      app.kubernetes.io/name: my-app
                  maxSkew: 1
                  topologyKey: kubernetes.io/hostname
                  whenUnsatisfiable: ScheduleAnyway
              volumes: null
      schedule: 0 */6 * * *
      successfulJobsHistoryLimit: 3
deployment:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: my-app
        app.kubernetes.io/version: 1.0.0
      name: RELEASE-NAME
    spec:
      replicas: 1
      revisionHistoryLimit: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: my-app
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/name: my-app
        spec:
          containers:
            - image: 123456.dkr.ecr.eu-central-1.amazonaws.com/my-app:1.0.0
              imagePullPolicy: IfNotPresent
              name: app
              ports:
                - containerPort: 8080
                  name: app
                  protocol: TCP
              resources:
                requests:
                  cpu: 100m
                  memory: 128Mi
          enableServiceLinks: false
          nodeSelector: null
          serviceAccountName: RELEASE-NAME
          tolerations: null
          topologySpreadConstraints:
            - labelSelector:
                matchLabels:
                  app.kubernetes.io/instance: RELEASE-NAME
                  app.kubernetes.io/name: my-app
              maxSkew: 1
              topologyKey: topology.kubernetes.io/zone
              whenUnsatisfiable: ScheduleAnyway
            - labelSelector:
                matchLabels:
                  app.kubernetes.io/instance: RELEASE-NAME
                  app.kubernetes.io/name: my-app
              maxSkew: 1
              topologyKey: kubernetes.io/hostname
              whenUnsatisfiable: ScheduleAnyway
          volumes: null
  2: |
    apiVersion: policy/v1
    kind: PodDisruptionBudget
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: my-app
        app.kubernetes.io/version: 1.0.0
      name: RELEASE-NAME
    spec:
      minAvailable: 50%
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: my-app
  3: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: my-app
        app.kubernetes.io/version: 1.0.0
      name: RELEASE-NAME
    spec:
      ports:
        - name: app
          port: 80
          protocol: TCP
          targetPort: app
      selector:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/name: my-app
      type: ClusterIP
job:
  1: |
    apiVersion: batch/v1
    kind: Job
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: my-app
        app.kubernetes.io/version: 1.0.0
      name: RELEASE-NAME
    spec:
      backoffLimit: 3
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/name: my-app
        spec:
          containers:
            - image: 123456.dkr.ecr.eu-central-1.amazonaws.com/my-app:1.0.0
              imagePullPolicy: IfNotPresent
              name: app
              ports:
                - containerPort: 8080
                  name: app
                  protocol: TCP
              resources:
                requests:
                  cpu: 100m
                  memory: 128Mi
          enableServiceLinks: false
          nodeSelector: null
          restartPolicy: OnFailure
          serviceAccountName: RELEASE-NAME
          tolerations: null
          topologySpreadConstraints:
            - labelSelector:
                matchLabels:
                  app.kubernetes.io/instance: RELEASE-NAME
                  app.kubernetes.io/name: my-app
              maxSkew: 1
              topologyKey: topology.kubernetes.io/zone
              whenUnsatisfiable: ScheduleAnyway
            - labelSelector:
                matchLabels:
                  app.kubernetes.io/instance: RELEASE-NAME
                  app.kubernetes.io/name: my-app
              maxSkew: 1
              topologyKey: kubernetes.io/hostname
              whenUnsatisfiable: ScheduleAnyway
          volumes: null
      ttlSecondsAfterFinished: 300
